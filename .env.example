# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Paths
WESAD_ROOT=/path/to/WESAD
MODEL_PATH=/path/to/model/tcn_cognitive_load.pth

# Service ports
SIGNAL_SIMULATOR_PORT=8001
INFERENCE_SERVICE_PORT=8002
ORCHESTRATOR_PORT=8003
CHAT_SERVICE_PORT=8000

# Inter-service URLs
SIMULATOR_WS=ws://signal_simulator:8001/ws/stream
INFERENCE_WS=ws://inference_service:8002/ws/predictions

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cognitive_interface
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://admin:changeme@localhost:5432/cognitive_interface

# Inference
DEVICE=cpu
